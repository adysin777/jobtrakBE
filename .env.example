# Required
MONGODB_URI=mongodb://localhost:27017/jobtrak
PORT=8080
NODE_ENV=development

# Public URL of this API (ngrok or production). Used by workers and similar.
# BACKEND_URL=https://YOUR-SUBDOMAIN.ngrok-free.app
# PUBLIC_URL=https://YOUR-SUBDOMAIN.ngrok-free.app

# Browser app URL — OAuth redirects land here after Gmail/Calendar connect.
# FRONTEND_URL=http://localhost:5173

# Optional: comma-separated extra CORS origins (e.g. if the Vite app is served via ngrok).
# CORS_ALLOWED_ORIGINS=https://YOUR-FE.ngrok-free.app

# Google OAuth (same client id for Gmail + Calendar).
# Calendar connect requests userinfo.email + calendar scopes (see googleCalendar.service.ts).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Authorized redirect URI(s) in GCP must match these exactly (scheme, host, path, no trailing slash unless you registered one).

# Gmail inbox connect callback (required for inbox OAuth)
# GOOGLE_REDIRECT_URI=https://YOUR-SUBDOMAIN.ngrok-free.app/api/inboxes/callback/gmail

# Optional: dedicated Calendar callback. If unset, Calendar uses GOOGLE_REDIRECT_URI (shared inbox callback is supported via state=gcal:...).
# GOOGLE_CALENDAR_REDIRECT_URI=https://YOUR-SUBDOMAIN.ngrok-free.app/api/calendar/callback/google

# Other
# INGEST_SECRET=
# GMAIL_PUBSUB_TOPIC=
# REDIS_URL=
# STRIPE_...
